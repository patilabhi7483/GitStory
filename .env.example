# Groq AI API Key (FREE — supports llama-3.3-70b-versatile)
# Get your FREE key at: https://console.groq.com/
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# GitHub API Token (optional, for repository URL analysis)
GITHUB_API_TOKEN=YOUR_GITHUB_API_TOKEN_HERE

# Flask Secret Key
SECRET_KEY=YOUR_SECRET_KEY_HERE

# Flask Debug Mode
FLASK_DEBUG=false
